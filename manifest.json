{
    "manifest_version": 3,
    "name": "PniPinP",
    "version": "1.0",
    "permissions": ["activeTab", "scripting"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Move a video to PiP"
    },
    "web_accessible_resources": [
        {
            "resources": ["src/css/main.css"],
            "matches": ["<all_urls>"]
        },
        {
            "resources": ["dist/*.map"],
            "matches": ["<all_urls>"]
        }
    ]
}